rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Cards de gatos namespaceados por UID do guest (auth anônima).
    // Leitura pública: permite compartilhar a URL do card com qualquer um.
    // Escrita: apenas o próprio dono, limitada a imagens de até 10 MB.
    match /cards/{uid}/{cardId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Qualquer outro caminho permanece bloqueado.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
